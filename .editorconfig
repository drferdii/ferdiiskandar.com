# Per-app override; monorepo root .editorconfig provides defaults.
# Setting root = false so this layers on top of root rules instead of replacing them.
root = false

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
indent_style = space
indent_size = 2
trim_trailing_whitespace = true

[*.md]
trim_trailing_whitespace = false
