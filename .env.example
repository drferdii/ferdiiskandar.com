# AI Provider selection: "deepseek" (default), "openrouter", or "openai"
AI_PROVIDER=deepseek

# DeepSeek (required when AI_PROVIDER=deepseek)
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
ABBY_MODEL=deepseek-chat

# OpenAI (required when AI_PROVIDER=openai)
# OPENAI_API_KEY=
# ABBY_MODEL=gpt-4o-mini

# OpenRouter (required when AI_PROVIDER=openrouter)
# OPENROUTER_API_KEY=
# OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
# OPENROUTER_SITE_URL=https://ferdiiskandar.com
# OPENROUTER_APP_NAME=Abby by dr Ferdi Iskandar
# ABBY_MODEL=deepseek/deepseek-v4-flash

# Legacy — used only by /api/chat (ChatGuide). Not required for Abby.
NVIDIA_API_KEY=

# Abby lead capture: "console" for local development, "none" for fallback, "email" when a provider is implemented.
ABBY_LEAD_MODE=console
ABBY_LEAD_TO_EMAIL=
