# AI Provider selection: "gemini" (default), "deepseek", "openrouter", or "openai"
AI_PROVIDER=gemini

# Gemini (required when AI_PROVIDER=gemini)
GEMINI_API_KEY=
ABBY_MODEL=gemini-3.1-flash-lite

# DeepSeek (required when AI_PROVIDER=deepseek)
# DEEPSEEK_API_KEY=
# DEEPSEEK_BASE_URL=https://api.deepseek.com
# ABBY_MODEL=deepseek-chat

# OpenAI (required when AI_PROVIDER=openai)
# OPENAI_API_KEY=
# ABBY_MODEL=gpt-4o-mini

# OpenRouter (required when AI_PROVIDER=openrouter)
# OPENROUTER_API_KEY=
# OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
# OPENROUTER_SITE_URL=https://ferdiiskandar.com
# OPENROUTER_APP_NAME=Abby by dr Ferdi Iskandar
# ABBY_MODEL=openai/gpt-oss-120b:free
# ABBY_MODEL_FALLBACKS=openai/gpt-oss-20b:free,google/gemma-4-31b-it:free

# Legacy — used only by /api/chat (ChatGuide). Not required for Abby.
NVIDIA_API_KEY=

# Abby lead capture modes:
# - console: local development only, no external delivery
# - none: emergency fallback, accepts without persistence
# - database: PostgreSQL persistence only
# - database_email: PostgreSQL persistence + Resend notification
ABBY_LEAD_MODE=database_email
DATABASE_URL=postgres://user:password@localhost:5432/ferdiiskandar
DATABASE_SSL=true
ABBY_LEAD_RETENTION_DAYS=365
RESEND_API_KEY=
ABBY_LEAD_FROM_EMAIL=Abby <abby@ferdiiskandar.com>
ABBY_LEAD_TO_EMAIL=
